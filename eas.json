{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "testflight": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "teamId": "9J2KVZY4NS"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "android": {
        "gradleCommand": ":app:bundleRelease"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "your-apple-id@example.com"
      }
    },
    "production": {
      "ios": {
        "appleId": "your-apple-id@example.com"
      },
      "android": {
        "track": "production"
      }
    }
  }
}
