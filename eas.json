{
  "cli": {
    "version": ">= 15.0.12",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "cache": {
        "disabled": false
      }
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "testflight",
      "ios": {
        "simulator": false
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "cache": {
        "disabled": false
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "production",
      "ios": {
        "simulator": false
      },
      "android": {
        "gradleCommand": ":app:bundleRelease"
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "cache": {
        "disabled": false
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "mostapha4567@icloud.com",
        "ascAppId": "6742468897"
      }
    },
    "production": {
      "ios": {
        "appleId": "mostapha4567@icloud.com"
      },
      "android": {
        "track": "production"
      }
    }
  }
}